# Python bytecode/caches
__pycache__/
*.py[cod]
*$py.class

# PyInstaller / build logs
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.deprecated

# Virtual Environments
venv/
.venv/
env/
.env/
ENV/

# IDE Configuration
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ML Weights & Model Downloads (will auto-download on run)
*.pt
*.onnx
.insightface/

# Local storage uploads (keep target template folders clean)
storage/uploads/*.jpg
storage/uploads/*.jpeg
storage/uploads/*.png
!storage/uploads/.gitkeep
